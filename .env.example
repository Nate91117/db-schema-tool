# ── Database — SQL Server (Windows Authentication — recommended for Windows PCs) ──
DB_TYPE=mssql
DB_HOST=YOUR-SERVER\INSTANCE
DB_PORT=1433
DB_NAME=YourDatabase
DB_WINDOWS_AUTH=true
# ODBC_DRIVER=ODBC Driver 17 for SQL Server  # change if you have v18

# ── Database — SQL Server (SQL Authentication — service account) ──────────────
# DB_TYPE=mssql
# DB_HOST=192.168.1.100
# DB_PORT=1433
# DB_NAME=YourDatabase
# DB_USER=readonly_user
# DB_PASSWORD=

# ── Database — SQLite (local file) ────────────────────────────────────────────
# DB_TYPE=sqlite
# DB_PATH=local.db

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── SuperMemory (optional — pre-crawl knowledge fetch) ───────────────────────
# Get a free API key at https://console.supermemory.ai
# SUPERMEMORY_API_KEY=sm_...

# ── Crawler behavior ──────────────────────────────────────────────────────────
INDUSTRY=general
# Options: biofuel | manufacturing | food_processing | chemicals | general
